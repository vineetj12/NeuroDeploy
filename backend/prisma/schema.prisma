// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/PrismaClientManager/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id              String   @id @default(uuid())
  email           String   @unique
  password        String
  selectedModelId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  selectedModel AIModel?         @relation(fields: [selectedModelId], references: [id], onDelete: SetNull)
  modelKeys     UserModelKey[]
  credentials   UserCredential[]
  fixJobs       FixJob[]
  deadLetterJobs DeadLetterJob[]
}

model AIModel {
  id        String   @id @default(uuid())
  name      String   @unique
  provider  Provider
  isActive  Boolean  @default(true)
  isSelected Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users     User[]
  modelKey  UserModelKey?
}

model UserModelKey {
  id        String   @id @default(uuid())
  userId    String
  modelId   String @unique
  apiKey    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  model AIModel @relation(fields: [modelId], references: [id], onDelete: Cascade)

  @@unique([userId, modelId])
}

model UserCredential {
  id        String             @id @default(uuid())
  userId    String
  provider  CredentialProvider
  name      String
  secret    String
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider, name])
}

model FixJob {
  id              String         @id @default(uuid())
  userId          String
  projectId       String
  projectName     String?
  deploymentId    String?
  bullmqJobId     String?
  status          FixJobStatus   @default(QUEUED)
  errorCategory   ErrorCategory  @default(UNKNOWN)
  errorMessage    String?
  patchJson       Json?
  aiProvider      String?
  aiModel         String?
  confidenceScore Float?
  riskLevel       String?
  durationMs      Int?
  filesChanged    Int            @default(0)
  fixedFiles      String[]       @default([])
  prUrl           String?
  startedAt       DateTime       @default(now())
  completedAt     DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, status])
  @@index([userId, createdAt])
}

model DeadLetterJob {
  id              String   @id @default(uuid())
  originalJobId   String
  userId          String?
  webhookPayload  Json
  failureReason   String
  failureStack    String?
  attemptCount    Int
  canReplay       Boolean  @default(true)
  replayedAt      DateTime?
  replayJobId     String?
  dismissedAt     DateTime?
  firstFailedAt   DateTime @default(now())
  lastFailedAt    DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([userId, dismissedAt])
  @@index([originalJobId])
}

enum FixJobStatus {
  QUEUED
  ANALYZING
  VALIDATING
  PR_CREATED
  FAILED
}

enum ErrorCategory {
  BUILD_ERROR
  TYPE_ERROR
  SYNTAX_ERROR
  MISSING_DEPENDENCY
  MISSING_ENV_VAR
  CONFIG_ERROR
  DEPENDENCY_CONFLICT
  RUNTIME_ERROR
  UNKNOWN
}

enum Provider {
  GEMINI
  ANTHROPIC
  OPENAI
  DEEPSEEK
  OTHER
}

enum CredentialProvider {
  GITHUB
  VERCEL
  CUSTOM
}
